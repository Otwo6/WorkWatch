{
  "manifest_version": 3,
  "name": "WorkWatch",
  "description": "Detects common employee monitoring and identity verification signals in browser network traffic.",
  "version": "0.1.3",
  "permissions": ["storage", "tabs", "webRequest", "downloads"],
  "host_permissions": ["<all_urls>", "http://127.0.0.1:5050/*", "http://localhost:5050/*"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["page-guard.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content-script.js"],
      "run_at": "document_start"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "WorkWatch",
    "default_popup": "popup.html"
  },
  "options_page": "options.html"
}
